#include <iostream>
#include <stdlib.h>
#include "MusicQueue.h"
using namespace std;

int main() {
    MusicQueue q;
    int opcion;

    // 5 canciones precargadas
    q.enqueue(1, "Blinding Lights", "The Weeknd", "After Hours", "3:20");
    q.enqueue(2, "As It Was", "Harry Styles", "Harry's House", "2:37");
    q.enqueue(3, "Levitating", "Dua Lipa", "Future Nostalgia", "3:23");
    q.enqueue(4, "Stay", "Kid LAROI & Bieber", "F*CK LOVE 3", "2:21");
    q.enqueue(5, "Heat Waves", "Glass Animals", "Dreamland", "3:59");

    do {
        system("cls");
        cout << "[:]Cola de Musica - Estilo Spotify\n\n";
        cout << "[1] Encolar cancion\n";
        cout << "[2] Reproducir (Dequeue)\n";
        cout << "[3] Ver cola completa\n";
        cout << "[4] Ver siguiente cancion\n";
        cout << "[5] Tamano de la cola\n";
        cout << "[0] Salir\n";
        cout << "\nIngresa tu opcion: ";
        cin >> opcion;

        switch (opcion) {
        case 1: {
            int id;
            string titulo, artista, album, duracion;
            system("cls");
            cout << "ID: ";       cin >> id;
            cin.ignore();
            cout << "Titulo: ";   getline(cin, titulo);
            cout << "Artista: ";  getline(cin, artista);
            cout << "Album: ";    getline(cin, album);
            cout << "Duracion: "; getline(cin, duracion);
            q.enqueue(id, titulo, artista, album, duracion);
            system("pause");
            break;
        }
        case 2: q.dequeue(); break;
        case 3: q.show();    break;
        case 4: q.top();     break;
        case 5: q.size();    break;
        case 0: return 0;
        default:
            cout << "Opcion invalida.\n";
            system("pause");
        }
    } while (opcion != 0);

    return 0;
}

#endif
