{
    bool res;
    if (PilaVacia())//(cima == -1)
    {
        cerr << "Se esta intentando quitar un elemento de una pila vacia (underflow)" << endl;
        res = false;
    }
    else

    {
        pila[cima];
        cima--;
        res = true;
    }

    return res;


}

bool Pila::PilaVacia()
{
    return cima == -1;
}

void Pila::LimpiarPila()
{
    cima = -1;
}


bool Pila::Iguales(Pila p)
{
    TipoDato a, b;
    TipoDato array[MAX];

    bool iguales = false;

    int i = cima;
    while (p.CimaPila(b) && array[i--] == b)
    {
        p.Desapilar();
    }
    if (i < 0 && p.PilaVacia())
        iguales = true;

    return iguales;
}

